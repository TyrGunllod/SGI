# Environment variables configuration for SGI (Sistema de Gestão Integrado)
# Copy this file to .env and update the values for your environment

# Backend Configuration
# PostgreSQL database connection string
DATABASE_URL=postgresql://postgres:senha@localhost:5432/mini-erp

# Secret key for JWT token signing (generate a secure 32-character key)
SECRET_KEY=sua_chave_32_digitos

# JWT algorithm (HS256 is recommended)
ALGORITHM=HS256

# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration time in days
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend Configuration
# Public API URL for the Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:8000